# ════════════════════════════════════════════════════════
# Palz Backend — Environment Variables
# ════════════════════════════════════════════════════════
# Copy this file to .env and adjust as needed. NEVER commit .env.

# ── Database ──
# Local: postgresql://postgres:password@localhost:5432/palz
# Remote: postgresql://postgres.<ref>@<pooler>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/palz

# ── Supabase (for file storage: user_photos, audio_users, video_verifications) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── JWT Secret — minimum 32 characters, boot fails otherwise ──
JWT_SECRET=dev-secret-local-palz-2025-at-least-32-chars

# ── API key required in the x-api-key header on all /api/* routes ──
SECRET_ACCESS_KEY=change-me

# ── RevenueCat webhook shared secret (dashboard → Integrations → Webhooks) ──
# MANDATORY in production (boot fails without it). In dev the webhook
# returns 503 when unset.
REVENUECAT_WEBHOOK_SECRET=change-me

# ── Server ──
PORT=3000
HOST=0.0.0.0

# ── Google OAuth (optional — Google login disabled when unset) ──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── CORS: comma-separated origins allowed in production (web clients) ──
ALLOWED_ORIGINS=

# ── Comma-separated IPs exempt from DDoS throttling (optional) ──
DDOS_IP_WHITELIST=

# ── Debug / Error Details (dev only) ──
EXPOSE_ERROR_DETAILS=true

# ── Set to "production" on Render ──
NODE_ENV=development
