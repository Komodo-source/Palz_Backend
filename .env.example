# ── Palz Backend Environment Variables ──

# Supabase Connection
SUPABASE_URL=https://kcglwtoegceicruwmxzo.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database (Supabase Pooler)
# Format: postgresql://postgres.<project-ref>@<pooler-host>:5432/postgres
DATABASE_URL=postgresql://postgres.kcglwtoegceicruwmxzo@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require

# JWT Secret — change to a random 256-bit hex string in production
JWT_SECRET=dev-secret-change-me

# Server
PORT=3000
HOST=0.0.0.0

# Google OAuth
GOOGLE_CLIENT_ID=639212474409-8q2g4e4hf7jqa88o7i70fq7m7c8rgpli.apps.googleusercontent.com

# ── Debug / Error Details ──
# Set to 'true' to expose full error messages in API responses (dev only)
# This can also be enabled per-request by sending header: x-debug: true
EXPOSE_ERROR_DETAILS=true

# ── Supabase Storage Buckets ──
# The backend uses these bucket names — make sure they exist in your Supabase project:
#   - user_photos   (for profile images)
#   - audio_users   (for voice fun facts)
#   - wall          (for wall posts)
