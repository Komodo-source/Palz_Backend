# ════════════════════════════════════════════════════════
# Palz Backend — Environment Variables
# ════════════════════════════════════════════════════════
# Copy this file to .env and adjust as needed.
# For local dev, the .env file is pre-configured.

# ── Database ──
# Local: postgresql://postgres:password@localhost:5432/palz
# Remote: postgresql://postgres.<ref>@<pooler>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/palz

# ── Supabase (for file storage) ──
SUPABASE_URL=https://kcglwtoegceicruwmxzo.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── JWT Secret ──
JWT_SECRET=dev-secret-local-palz-2025

# ── Server ──
PORT=3000
HOST=0.0.0.0

# ── Google OAuth ──
GOOGLE_CLIENT_ID=639212474409-8q2g4e4hf7jqa88o7i70fq7m7c8rgpli.apps.googleusercontent.com

# ── Debug / Error Details ──
EXPOSE_ERROR_DETAILS=true
